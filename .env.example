# Virtuoso Psychology — environment variables
# Copy to `.env` and fill in. The PUBLIC_ prefix exposes the value to client
# code (required for the Web3Forms access key used by the contact form).

# Web3Forms access key — create a free key at https://web3forms.com
# (associate it with cara@virtuosopsychology.com). Until set, the contact
# form will not deliver.
PUBLIC_WEB3FORMS_KEY=
