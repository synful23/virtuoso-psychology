---
import Button from "./Button.astro";

interface Props {
  eyebrow: string;
  ctaHref: string;
  ctaLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}
const {
  eyebrow,
  ctaHref,
  ctaLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="hero-section relative bg-navy-deep text-cream overflow-hidden">
  {/*
    Faded background film. Autoplays muted on loop, no controls/audio.
    A navy gradient fades it out on the left so the hero text stays readable.
    Desktop-only + reduced-motion-safe (hidden when motion is reduced).
  */}
  <div class="hero-video hidden md:block" aria-hidden="true">
    <video
      class="hero-video__el"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      tabindex="-1"
    >
      <source src="/video/herobg.mp4" type="video/mp4" />
    </video>
    <div class="hero-video__scrim"></div>
  </div>

  <div class="relative z-10 px-6 md:px-12 pt-14 md:pt-20 pb-16 md:pb-24 grid md:grid-cols-12 gap-8 items-end">
    <div class="md:col-span-8">
      <p
        class="uppercase tracking-[0.25em] text-xs mb-5 text-gold"
        style="font-family: var(--font-display-sans);"
      >
        {eyebrow}
      </p>

      {/*
        Headline leads with the brand promise itself — set oversized in cream as
        the opening statement, with "Recruit the best" picked out in gold.
      */}
      <h1 class="text-cream">
        <span class="headline-lead block select-none">
          Know your people.<br />
          Recruit the best.<br />
          <span class="text-gold">Be the best.</span>
        </span>
      </h1>

      <p class="mt-8 max-w-xl text-base md:text-lg leading-relaxed text-ink-on-dark">
        Virtuoso Psychology offers certified experience and specific expertise in
        high performance. We don't believe psychology is a product to be sold, but a
        relationship — built on deep understanding and evidence-based practice to
        help you reach your goals.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <Button href={ctaHref} variant="primary">{ctaLabel} →</Button>
        {secondaryHref && secondaryLabel && (
          <Button href={secondaryHref} variant="secondary-dark">{secondaryLabel}</Button>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Faded background film ── */
  .hero-video {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero-video__el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  /* Fade the film into the navy on the left (behind the text) and soften the
     edges so it never competes with the headline. */
  .hero-video__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        var(--color-navy-deep) 0%,
        var(--color-navy-deep) 32%,
        color-mix(in srgb, var(--color-navy-deep) 72%, transparent) 55%,
        color-mix(in srgb, var(--color-navy-deep) 35%, transparent) 100%
      ),
      linear-gradient(
        to bottom,
        var(--color-navy-deep) 0%,
        transparent 22%,
        transparent 78%,
        var(--color-navy-deep) 100%
      );
  }

  /* Honour reduced-motion: no autoplaying film, fall back to the navy ground. */
  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none;
    }
  }

  /* The oversized brand promise — the headline's leading statement. */
  .headline-lead {
    font-family: var(--font-display-serif);
    font-weight: 700;
    font-size: clamp(40px, 8vw, 104px);
    line-height: 1.02;
    letter-spacing: -0.025em;
  }

  /* Subtle one-time rise-in for the headline (motion users only). */
  @media (prefers-reduced-motion: no-preference) {
    .headline-lead {
      animation: headline-rise 800ms cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes headline-rise {
      from {
        opacity: 0;
        transform: translateY(0.1em);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
