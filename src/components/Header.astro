---
import { nav } from "../data/site";
import BrandLockup from "./BrandLockup.astro";

interface Props {
  /** Visual theme: "dark" sits on navy, "light" sits on cream/paper. */
  theme?: "dark" | "light";
}
const { theme = "light" } = Astro.props;

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? current === "/" : current.startsWith(href);

const onDark = theme === "dark";
const bar = onDark ? "bg-navy-deep text-cream" : "bg-paper text-ink";
const accent = onDark ? "text-gold" : "text-gold-deep";
const linkBase = onDark ? "text-cream/80 hover:text-cream" : "text-ink/70 hover:text-ink";
const border = onDark ? "border-cream/10" : "border-ink/10";
---

<header class:list={[bar, "border-b", border, "sticky top-0 z-40"]}>
  <div class="px-6 md:px-12 py-5 flex items-center justify-between gap-6">
    <BrandLockup theme={theme} height={48} />

    {/* Desktop nav */}
    <nav class="hidden md:block" aria-label="Primary">
      <ul class="flex items-center gap-8 text-sm" style="font-family: var(--font-display-sans);">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "uppercase tracking-[0.15em] transition-colors duration-200 pb-1",
                isActive(item.href)
                  ? `${accent} border-b-2 border-current`
                  : linkBase,
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* Mobile nav — zero-JS disclosure */}
    <details class="md:hidden relative group">
      <summary
        class="list-none cursor-pointer uppercase tracking-[0.15em] text-xs font-bold flex items-center gap-2 select-none"
        style="font-family: var(--font-display-sans);"
        aria-label="Open menu"
      >
        <span class="group-open:hidden">Menu</span>
        <span class="hidden group-open:inline">Close</span>
        <span aria-hidden="true" class="text-lg leading-none">
          <span class="group-open:hidden">≡</span>
          <span class="hidden group-open:inline">×</span>
        </span>
      </summary>
      <nav
        class:list={[
          "absolute right-0 mt-4 w-56 border shadow-lg z-50",
          onDark ? "bg-navy-mid border-cream/10" : "bg-paper border-ink/10",
        ]}
        aria-label="Mobile primary"
      >
        <ul style="font-family: var(--font-display-sans);">
          {nav.map((item) => (
            <li class:list={["border-b last:border-b-0", border]}>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "block px-5 py-4 uppercase tracking-[0.15em] text-sm transition-colors duration-200",
                  isActive(item.href) ? accent : linkBase,
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>
  </div>
</header>
