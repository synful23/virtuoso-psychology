---
import Button from "./Button.astro";

interface Props {
  heading?: string;
  body?: string;
  ctaHref?: string;
  ctaLabel?: string;
}
const {
  heading = "Let's start with a conversation.",
  body = "No pitch, no pressure. Just a chance to talk about your team, your moment, and whether we're the right fit.",
  ctaHref = "/contact",
  ctaLabel = "Book a discovery call",
} = Astro.props;
---

<section class="bg-navy-deep text-cream">
  <div class="px-6 md:px-12 py-20 md:py-28 grid md:grid-cols-12 gap-8 items-center">
    <div class="md:col-span-8">
      <h2
        class="leading-[1.05] tracking-[-0.01em]"
        style="font-family: var(--font-display-serif); font-weight: 600; font-size: clamp(32px, 5vw, 64px);"
      >
        {heading}
      </h2>
      <p class="mt-6 max-w-xl text-base md:text-lg leading-relaxed text-ink-on-dark">
        {body}
      </p>
    </div>
    <div class="md:col-span-4 flex md:justify-end">
      <Button href={ctaHref} variant="primary">{ctaLabel} →</Button>
    </div>
  </div>
</section>
