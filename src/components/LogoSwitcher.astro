---
import { logoExperiment } from "../data/site";
/*
  Floating logo experiment tool (temporary, bottom-right).
  Lets Cara compare image marks live: clicking a swatch sets html[data-logo]
  and saves to localStorage, so every BrandLockup on the page swaps instantly
  and the choice follows her across pages. Remove <LogoSwitcher/> from
  BaseLayout to retire the experiment.
*/
const { marks } = logoExperiment;
---

<div class="logo-switcher" data-logo-switcher>
  <button
    type="button"
    class="logo-switcher__toggle"
    aria-expanded="false"
    aria-controls="logo-switcher-panel"
    aria-label="Try a different logo"
    title="Try a different logo"
  >
    <span class="logo-switcher__dot" aria-hidden="true">🎨</span>
    <span class="logo-switcher__toggle-label">Logo</span>
  </button>

  <div id="logo-switcher-panel" class="logo-switcher__panel" role="dialog" aria-label="Choose a logo mark" hidden>
    <p class="logo-switcher__title">Experiment · choose a mark</p>
    <div class="logo-switcher__grid">
      {marks.map((m) => (
        <button
          type="button"
          class="logo-switcher__swatch"
          data-logo-choice={m.id}
          aria-pressed="false"
          title={m.label}
        >
          <img src={m.normal} alt="" class="logo-switcher__swatch-img" loading="lazy" decoding="async" />
          <span class="logo-switcher__swatch-label">{m.label}</span>
        </button>
      ))}
      <button type="button" class="logo-switcher__swatch logo-switcher__swatch--none" data-logo-choice="none" aria-pressed="false" title="Wordmark only">
        <span class="logo-switcher__none" aria-hidden="true">Aa</span>
        <span class="logo-switcher__swatch-label">Wordmark only</span>
      </button>
    </div>
  </div>
</div>

<style>
  .logo-switcher {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    font-family: var(--font-display-sans);
  }

  .logo-switcher__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: var(--color-navy-deep);
    color: var(--color-cream);
    border: 1px solid var(--color-gold);
    border-radius: 999px;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(11, 27, 51, 0.35);
    transition: background-color 0.2s, transform 0.2s;
  }
  .logo-switcher__toggle:hover {
    background: var(--color-navy-mid);
    transform: translateY(-1px);
  }
  .logo-switcher__dot {
    background: none;
  }

  .logo-switcher__panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.75rem);
    width: 16rem;
    background: var(--color-paper);
    color: var(--color-ink);
    border: 1px solid color-mix(in srgb, var(--color-ink) 12%, transparent);
    border-radius: 0.5rem;
    box-shadow: 0 12px 36px rgba(11, 27, 51, 0.25);
    padding: 1rem;
  }
  .logo-switcher__panel[hidden] {
    display: none;
  }

  .logo-switcher__title {
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 0.75rem;
    font-weight: 700;
  }

  .logo-switcher__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .logo-switcher__swatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.35rem;
    background: var(--color-cream);
    border: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
    border-radius: 0.375rem;
    cursor: pointer;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .logo-switcher__swatch:hover {
    border-color: var(--color-gold-deep);
  }
  .logo-switcher__swatch[aria-pressed="true"] {
    border-color: var(--color-gold-deep);
    background: color-mix(in srgb, var(--color-gold-soft) 35%, var(--color-cream));
  }

  .logo-switcher__swatch-img {
    height: 2.25rem;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }
  .logo-switcher__none {
    height: 2.25rem;
    display: flex;
    align-items: center;
    font-family: var(--font-display-serif);
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--color-navy-deep);
  }
  .logo-switcher__swatch-label {
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    text-align: center;
    line-height: 1.2;
  }
</style>

<script>
  const STORAGE_KEY = "vp-logo";
  const root = document.querySelector<HTMLElement>("[data-logo-switcher]");
  if (root) {
    const toggle = root.querySelector<HTMLButtonElement>(".logo-switcher__toggle")!;
    const panel = root.querySelector<HTMLElement>(".logo-switcher__panel")!;
    const swatches = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-logo-choice]"),
    );

    const current = () => document.documentElement.dataset.logo ?? "logo3";

    const syncPressed = () => {
      const c = current();
      swatches.forEach((s) =>
        s.setAttribute("aria-pressed", String(s.dataset.logoChoice === c)),
      );
    };

    const openPanel = (open: boolean) => {
      panel.hidden = !open;
      toggle.setAttribute("aria-expanded", String(open));
    };

    toggle.addEventListener("click", () => openPanel(panel.hidden));

    // Convenience: ?logopanel opens the picker on load (handy for sharing).
    if (new URLSearchParams(location.search).has("logopanel")) openPanel(true);

    swatches.forEach((s) => {
      s.addEventListener("click", () => {
        const choice = s.dataset.logoChoice!;
        document.documentElement.dataset.logo = choice;
        try {
          localStorage.setItem(STORAGE_KEY, choice);
        } catch (e) {
          /* ignore */
        }
        syncPressed();
      });
    });

    // Close on outside click or Escape.
    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) openPanel(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") openPanel(false);
    });

    syncPressed();
  }
</script>
