---
import { nav, site } from "../data/site";
import BrandLockup from "./BrandLockup.astro";
const year = new Date().getFullYear();
---

<footer class="bg-navy-deep text-ink-on-dark">
  <div class="px-6 md:px-12 py-16 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <BrandLockup theme="dark" height={52} class="mb-6" />
      <h2
        class="text-2xl md:text-3xl leading-[1.15] text-cream"
        style="font-family: var(--font-display-serif); font-weight: 600;"
      >
        Know your people.<br />Recruit the best.<br /><span class="text-gold">Be the best.</span>
      </h2>
    </div>

    <nav class="md:col-span-3" aria-label="Footer">
      <p class="uppercase tracking-[0.2em] text-[11px] mb-4 text-gold" style="font-family: var(--font-display-sans);">
        Site
      </p>
      <ul class="space-y-2 text-sm" style="font-family: var(--font-display-sans);">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-ink-on-dark hover:text-cream transition-colors duration-200"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="md:col-span-4">
      <p class="uppercase tracking-[0.2em] text-[11px] mb-4 text-gold" style="font-family: var(--font-display-sans);">
        Get in touch
      </p>
      <p class="text-sm leading-relaxed">
        For teams &amp; organisations, leaders &amp; individuals, and speaking engagements.<br />
        <a
          href={`mailto:${site.email}`}
          class="text-cream underline underline-offset-4 hover:opacity-70 transition-opacity"
        >
          {site.email}
        </a>
      </p>
      <div class="mt-5 flex gap-5 text-sm" style="font-family: var(--font-display-sans);">
        <a
          href={site.social.instagram}
          class="text-ink-on-dark hover:text-cream transition-colors duration-200"
          rel="me noopener"
          target="_blank"
        >
          Instagram
        </a>
        <a
          href={site.social.linkedin}
          class="text-ink-on-dark hover:text-cream transition-colors duration-200"
          rel="me noopener"
          target="_blank"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>

  <div
    class="px-6 md:px-12 py-6 border-t border-cream/10 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between text-[11px] uppercase tracking-[0.2em]"
    style="font-family: var(--font-display-sans);"
  >
    <p>© {site.name} {year} · BPS · HCPC registered</p>
    <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Legal">
      <a href="/privacy" class="text-ink-on-dark hover:text-cream transition-colors duration-200">
        Privacy &amp; cookies
      </a>
      <button
        type="button"
        data-manage-consent
        class="uppercase tracking-[0.2em] text-ink-on-dark hover:text-cream transition-colors duration-200 cursor-pointer"
      >
        Manage cookies
      </button>
    </nav>
  </div>
</footer>

<script>
  // Re-open the consent banner so visitors can withdraw consent as easily as
  // they gave it (PECR). `vpManageConsent` is defined by ConsentBanner.
  document
    .querySelector("[data-manage-consent]")
    ?.addEventListener("click", () => {
      (window as unknown as { vpManageConsent?: () => void }).vpManageConsent?.();
    });
</script>
