---
/*
  Cookie consent banner — UK GDPR / PECR compliant.

  Principles enforced here:
   - No non-essential script runs before opt-in (analytics is gated; see BaseLayout).
   - "Reject" is exactly as easy as "Accept" (equal-weight buttons, no dark patterns).
   - The choice (and policy version) is recorded in localStorage, NOT a cookie —
     storing a consent preference is "strictly necessary" and needs no consent.
   - Granting consent dispatches `vp-consent-granted`; the analytics loader listens.
   - `window.vpManageConsent()` re-opens the banner (wired to the footer link) so
     visitors can withdraw consent as easily as they gave it.

  Progressive enhancement: with JS off, nothing tracks and the banner stays hidden
  (there is nothing to consent to without JS), so no broken/inert UI is shown.
*/
import { consent } from "../data/site";
---

<div
  id="consent-banner"
  class="fixed inset-x-0 bottom-0 z-[60] hidden border-t border-gold/30 bg-navy-deep text-cream"
  role="dialog"
  aria-modal="false"
  aria-label="Cookie consent"
  aria-describedby="consent-message"
  hidden
>
  <div class="mx-auto max-w-6xl px-6 md:px-12 py-5 flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
    <p
      id="consent-message"
      class="text-sm leading-relaxed text-ink-on-dark flex-1"
      style="font-family: var(--font-display-sans);"
    >
      {consent.message}{" "}
      <a
        href={consent.policyHref}
        class="text-cream underline underline-offset-4 hover:text-gold transition-colors"
      >
        Privacy &amp; cookies
      </a>
    </p>
    <div class="flex gap-3 shrink-0" style="font-family: var(--font-display-sans);">
      <button
        type="button"
        data-consent="reject"
        class="px-6 py-3 text-sm font-semibold uppercase tracking-[0.15em] border border-cream text-cream hover:bg-cream hover:text-navy-deep transition-colors duration-200 cursor-pointer"
      >
        Reject
      </button>
      <button
        type="button"
        data-consent="accept"
        class="px-6 py-3 text-sm font-bold uppercase tracking-[0.15em] bg-gold text-navy-deep hover:bg-gold-deep hover:text-cream transition-colors duration-200 cursor-pointer"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ KEY: consent.storageKey, VERSION: consent.version }}>
  (() => {
    const banner = document.getElementById("consent-banner");
    if (!banner) return;

    const read = () => {
      try {
        const raw = localStorage.getItem(KEY);
        return raw ? JSON.parse(raw) : null;
      } catch {
        return null;
      }
    };

    const save = (status) => {
      try {
        localStorage.setItem(
          KEY,
          JSON.stringify({ status, version: VERSION, at: new Date().toISOString() }),
        );
      } catch {
        /* localStorage blocked — treat as no consent, never track */
      }
    };

    const show = () => {
      banner.hidden = false;
      banner.classList.remove("hidden");
    };
    const hide = () => {
      banner.hidden = true;
      banner.classList.add("hidden");
    };

    const grant = () => {
      // Notify the analytics loader (and any future gated script).
      window.dispatchEvent(new CustomEvent("vp-consent-granted"));
    };

    const decide = (status) => {
      save(status);
      hide();
      if (status === "accepted") grant();
    };

    // Re-open for "Manage cookies" / withdrawal. Exposed globally on purpose.
    window.vpManageConsent = show;

    banner
      .querySelector('[data-consent="accept"]')
      ?.addEventListener("click", () => decide("accepted"));
    banner
      .querySelector('[data-consent="reject"]')
      ?.addEventListener("click", () => decide("rejected"));

    // Decide initial state. Re-prompt if the stored policy version is stale.
    const stored = read();
    if (!stored || stored.version !== VERSION) {
      show();
    } else if (stored.status === "accepted") {
      grant(); // already opted in on a previous visit → load analytics now
    }
  })();
</script>
