---
/*
  Link-styled button. CSS-only hover (replaces a.astro's onmouseover handlers).
  Variants:
   - primary           gold on navy surfaces → inverts to gold-deep/cream
   - primary-on-light  navy on light surfaces
   - secondary-dark    outlined for navy surfaces (border cream)
   - secondary-light   outlined for light surfaces (border navy)
   - inline            underlined inline link
*/
interface Props {
  href: string;
  variant?:
    | "primary"
    | "primary-on-light"
    | "secondary-dark"
    | "secondary-light"
    | "inline";
  class?: string;
}

const { href, variant = "primary", class: className = "" } = Astro.props;

const base =
  "inline-block uppercase tracking-[0.15em] text-sm transition-colors duration-200";
const box = "px-7 py-4 font-bold";

const variants: Record<string, string> = {
  primary: `${box} bg-gold text-navy-deep hover:bg-gold-deep hover:text-cream`,
  "primary-on-light": `${box} bg-navy-deep text-cream hover:bg-navy-mid`,
  "secondary-dark": `${box} border border-cream text-cream hover:bg-cream hover:text-navy-deep font-semibold`,
  "secondary-light": `${box} border border-navy-deep text-navy-deep hover:bg-navy-deep hover:text-cream font-semibold`,
  inline:
    "inline-block uppercase tracking-[0.2em] text-xs pb-1 font-bold text-gold-deep border-b border-gold-deep transition-colors duration-200 hover:text-navy-deep hover:border-navy-deep",
};

const isInline = variant === "inline";
---

<a
  href={href}
  class:list={[isInline ? "" : base, variants[variant], className]}
  style="font-family: var(--font-display-sans);"
>
  <slot />
</a>
