---
/*
  A single "How it works" step with an oversized editorial Fraunces numeral.
  Sits on light surfaces.
*/
interface Props {
  number: string;
  title: string;
  body: string;
}
const { number, title, body } = Astro.props;
---

<div class="border-t-2 border-gold-deep pt-6">
  <p
    class="leading-none text-gold-deep mb-4"
    style="font-family: var(--font-display-serif); font-weight: 600; font-size: clamp(56px, 8vw, 96px);"
    aria-hidden="true"
  >
    {number}
  </p>
  <h3 class="text-2xl md:text-3xl mb-3 text-ink" style="font-family: var(--font-display-serif); font-weight: 600;">
    {title}
  </h3>
  <p class="text-base leading-relaxed text-ink-muted max-w-sm">
    {body}
  </p>
</div>
