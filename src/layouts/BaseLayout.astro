---
import "../styles/global.css";
import { site as siteData, logoExperiment } from "../data/site";

const defaultLogoMark = logoExperiment.defaultMark;

// Self-hosted fonts (no Google Fonts CDN — avoids sending visitor IPs to a
// third party, which is a UK-GDPR liability). Served from our own domain.
import "@fontsource-variable/fraunces"; // wght 100–900, normal
import "@fontsource-variable/fraunces/wght-italic.css"; // italic axis (pull-quotes)
import "@fontsource/archivo/500.css";
import "@fontsource/archivo/700.css";
import "@fontsource/archivo/900.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "High performance specialists in sport and business — helping you know your people, recruit the best, and be the best.",
  ogImage = "/og-default.png",
  noindex = false,
  canonicalPath,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL("https://www.virtuosopsychology.com");
const canonicalURL = new URL(canonicalPath ?? Astro.url.pathname, site);
const ogImageURL = new URL(ogImage, site);

// Default structured data: the practice (ProfessionalService) + Cara (Person).
// Placeholder values are flagged; swap when Cara confirms credentials.
const defaultJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Virtuoso Psychology",
  description,
  url: site.href,
  areaServed: "GB",
  image: ogImageURL.href,
  sameAs: [siteData.social.instagram],
  founder: {
    "@type": "Person",
    name: siteData.founderName,
    jobTitle: siteData.founderRole,
  },
  knowsAbout: [
    "Performance psychology",
    "High performance culture",
    "Recruitment and onboarding",
    "Leadership coaching",
    "Performance under pressure",
  ],
};

const structuredData = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/*
      Logo locked to the chosen mark (set on <html> before paint, no flash).
      The experiment is retired: any stale saved choice is cleared so the
      default always wins.
    */}
    <script is:inline define:vars={{ defaultMark: defaultLogoMark }}>
      document.documentElement.dataset.logo = defaultMark;
      try {
        localStorage.removeItem("vp-logo");
      } catch (e) {
        /* ignore */
      }
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Virtuoso Psychology" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    {/* Structured data */}
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    {/*
      Cookieless analytics slot (no cookie banner needed). Uncomment and set
      the domain once Cara confirms a Plausible / Cloudflare Web Analytics account.
      <script defer data-domain="virtuosopsychology.com" src="https://plausible.io/js/script.js"></script>
    */}
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-navy-deep focus:px-5 focus:py-3 focus:text-cream focus:no-underline"
      style="font-family: var(--font-display-sans);"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
