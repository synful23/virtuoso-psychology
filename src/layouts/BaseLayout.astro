---
import "../styles/global.css";
import { site as siteData, sameAs, logoExperiment } from "../data/site";

const defaultLogoMark = logoExperiment.defaultMark;

// Self-hosted fonts (no Google Fonts CDN — avoids sending visitor IPs to a
// third party, which is a UK-GDPR liability). Served from our own domain.
import "@fontsource-variable/fraunces"; // wght 100–900, normal
import "@fontsource-variable/fraunces/wght-italic.css"; // italic axis (pull-quotes)
import "@fontsource/archivo/500.css";
import "@fontsource/archivo/700.css";
import "@fontsource/archivo/900.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/600.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  canonicalPath?: string;
  /**
   * Page-specific schema (e.g. Person on /about, Service on /services). It is
   * added to the @graph alongside the always-present Organization + WebSite, so
   * entity relationships stay intact on every page.
   */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "High performance specialists in sport and business — helping you know your people, recruit the best, and be the best.",
  ogImage = "/og-default.png",
  ogImageAlt = "Virtuoso Psychology — performance psychology for sport and business.",
  noindex = false,
  canonicalPath,
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL("https://www.virtuosopsychology.com");
const canonicalURL = new URL(canonicalPath ?? Astro.url.pathname, site);
const ogImageURL = new URL(ogImage, site);

// Stable @id anchors so nodes across the graph can reference one another.
const orgId = `${site.href}#organisation`;
const websiteId = `${site.href}#website`;

// The practice as an entity (ProfessionalService is a subtype of Organization).
// Acts as publisher of the WebSite and provider referenced by page Service nodes.
const organisation = {
  "@type": ["Organization", "ProfessionalService"],
  "@id": orgId,
  name: siteData.name,
  description: siteData.description,
  url: site.href,
  image: new URL("/og-default.png", site).href,
  areaServed: [...siteData.areaServed],
  knowsAbout: [...siteData.knowsAbout],
  slogan: "Know your people. Recruit the best. Be the best.",
  sameAs,
  email: siteData.email,
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "enquiries",
    email: siteData.email,
    areaServed: [...siteData.areaServed],
    availableLanguage: ["English"],
  },
  founder: {
    "@type": "Person",
    name: siteData.founderName,
    jobTitle: siteData.founderRole,
    sameAs,
  },
};

const website = {
  "@type": "WebSite",
  "@id": websiteId,
  name: siteData.name,
  url: site.href,
  inLanguage: "en-GB",
  publisher: { "@id": orgId },
};

// Always emit Organization + WebSite; append any page-specific node(s).
const pageNodes = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
// Strip @context from page nodes — the graph carries one shared context.
const cleanedPageNodes = pageNodes.map(({ ["@context"]: _ctx, ...rest }) => rest);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [organisation, website, ...cleanedPageNodes],
};

const robotsContent = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1";
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/*
      Logo locked to the chosen mark (set on <html> before paint, no flash).
      The experiment is retired: any stale saved choice is cleared so the
      default always wins.
    */}
    <script is:inline define:vars={{ defaultMark: defaultLogoMark }}>
      document.documentElement.dataset.logo = defaultMark;
      try {
        localStorage.removeItem("vp-logo");
      } catch (e) {
        /* ignore */
      }
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteData.founderName} />
    <meta name="robots" content={robotsContent} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    {/* Identity verification for E-E-A-T (rel=me to owned profiles). */}
    {sameAs.map((href) => (
      <link rel="me" href={href} />
    ))}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Virtuoso Psychology" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {/* Structured data */}
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    {/*
      Cookieless analytics slot (no cookie banner needed). Uncomment and set
      the domain once Cara confirms a Plausible / Cloudflare Web Analytics account.
      <script defer data-domain="virtuosopsychology.com" src="https://plausible.io/js/script.js"></script>
    */}
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-navy-deep focus:px-5 focus:py-3 focus:text-cream focus:no-underline"
      style="font-family: var(--font-display-sans);"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
