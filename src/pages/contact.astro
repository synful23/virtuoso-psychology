---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";

// PLACEHOLDER — create a free key at https://web3forms.com and set
// PUBLIC_WEB3FORMS_KEY in your .env. Until then the form will not deliver.
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "";

// No-JS fallback: Web3Forms redirects here on success.
const justSent = Astro.url.searchParams.get("sent") === "1";

const inputClass =
  "w-full bg-paper border border-ink/20 px-4 py-3 text-ink text-base focus:border-gold-deep focus:outline-none transition-colors duration-200";
const labelClass = "block uppercase tracking-[0.15em] text-[11px] mb-2 text-ink font-bold";
---

<BaseLayout
  title="Contact · Virtuoso Psychology"
  description="Start a conversation about your team, athlete, or speaking enquiry. No pitch, no pressure — just a chance to see if we're the right fit."
>
  <Header theme="light" />
  <main id="main-content">
    <section class="bg-cream text-ink">
      <div class="px-6 md:px-12 py-16 md:py-24 grid md:grid-cols-12 gap-10">
        {/* Left — intro + direct contact */}
        <div class="md:col-span-5">
          <p class="uppercase tracking-[0.25em] text-xs mb-4 text-gold-deep" style="font-family: var(--font-display-sans);">
            Contact
          </p>
          <h1 class="text-4xl md:text-6xl leading-[1.05] tracking-[-0.01em]" style="font-family: var(--font-display-serif); font-weight: 600;">
            Let's talk.
          </h1>
          <p class="mt-8 max-w-md text-base md:text-lg leading-relaxed text-ink-muted">
            Tell us a little about your team, your athlete, or your event. We'll
            get back to you within a couple of working days.
          </p>

          <div class="mt-10 space-y-6 text-sm" style="font-family: var(--font-display-sans);">
            <div>
              <p class="uppercase tracking-[0.18em] text-[11px] mb-2 text-gold-deep font-bold">Email</p>
              <a href={`mailto:${site.email}`} class="text-ink underline underline-offset-4 hover:text-gold-deep transition-colors">
                {site.email}
              </a>
            </div>
            <div>
              <p class="uppercase tracking-[0.18em] text-[11px] mb-2 text-gold-deep font-bold">Elsewhere</p>
              <div class="flex gap-5">
                <a href={site.social.instagram} rel="me noopener" target="_blank" class="text-ink hover:text-gold-deep transition-colors">Instagram</a>
                <a href={site.social.linkedin} rel="me noopener" target="_blank" class="text-ink hover:text-gold-deep transition-colors">LinkedIn</a>
              </div>
            </div>
          </div>
        </div>

        {/* Right — form */}
        <div class="md:col-span-7">
          {/* aria-live region announces success/error for AT + JS users */}
          <p
            id="form-status"
            role="status"
            aria-live="polite"
            class:list={[
              "mb-6 px-4 py-3 text-sm border",
              justSent ? "border-gold-deep bg-gold-soft/30 text-ink" : "hidden",
            ]}
          >
            {justSent && "Thank you — your message has been sent. We'll be in touch shortly."}
          </p>

          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-6"
          >
            <input type="hidden" name="access_key" value={accessKey} />
            <input type="hidden" name="subject" value="New enquiry — Virtuoso Psychology" />
            <input type="hidden" name="from_name" value="Virtuoso Psychology website" />
            {/* No-JS success redirect */}
            <input type="hidden" name="redirect" value={`${site.url}/contact?sent=1`} />
            {/* Honeypot (Web3Forms native) — hidden from people, catches bots */}
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display:none"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />

            <div>
              <label for="name" class={labelClass}>Name</label>
              <input id="name" name="name" type="text" required aria-required="true" autocomplete="name" class={inputClass} />
            </div>

            <div>
              <label for="email" class={labelClass}>Email</label>
              <input id="email" name="email" type="email" required aria-required="true" autocomplete="email" class={inputClass} />
            </div>

            <fieldset>
              <legend class={labelClass}>This enquiry is about</legend>
              <div class="flex flex-wrap gap-x-6 gap-y-2" style="font-family: var(--font-display-sans);">
                {["A team", "An individual", "Speaking", "Something else"].map((opt, i) => (
                  <label class="flex items-center gap-2 text-sm text-ink cursor-pointer">
                    <input type="radio" name="enquiry_type" value={opt} checked={i === 0} class="accent-[#A07628]" />
                    {opt}
                  </label>
                ))}
              </div>
            </fieldset>

            <div>
              <label for="message" class={labelClass}>Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                aria-required="true"
                aria-describedby="message-hint"
                class={inputClass}
              ></textarea>
              <p id="message-hint" class="mt-2 text-xs text-ink-muted">
                A sentence or two about your moment is plenty to start.
              </p>
            </div>

            <button
              type="submit"
              class="inline-block px-7 py-4 uppercase tracking-[0.15em] text-sm font-bold bg-navy-deep text-cream hover:bg-navy-mid transition-colors duration-200 cursor-pointer disabled:opacity-60"
              style="font-family: var(--font-display-sans);"
            >
              Send message →
            </button>

            {!accessKey && (
              <p class="text-xs text-ink-muted">
                {/* Build-time note (visible only until the key is set). */}
                Note: the form access key isn't configured yet, so submissions
                won't be delivered. Use the email above in the meantime.
              </p>
            )}
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Progressive enhancement: submit via fetch + announce in the live region.
  // No-JS users still get a native POST + redirect to /contact?sent=1.
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");
  if (form && status) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const button = form.querySelector("button[type=submit]") as HTMLButtonElement;
      const show = (msg: string, ok: boolean) => {
        status.textContent = msg;
        status.classList.remove("hidden");
        status.className =
          "mb-6 px-4 py-3 text-sm border " +
          (ok
            ? "border-gold-deep bg-gold-soft/30 text-ink"
            : "border-red-700 bg-red-50 text-red-900");
      };
      try {
        button.disabled = true;
        button.textContent = "Sending…";
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        const data = await res.json();
        if (res.ok && data.success) {
          show("Thank you — your message has been sent. We'll be in touch shortly.", true);
          form.reset();
          status.focus?.();
        } else {
          throw new Error(data.message || "Submission failed");
        }
      } catch {
        show(
          "Sorry — something went wrong sending that. Please email us directly and we'll pick it up.",
          false,
        );
      } finally {
        button.disabled = false;
        button.textContent = "Send message →";
      }
    });
  }
</script>
