---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import CredibilityBand from "../components/CredibilityBand.astro";
import PullQuote from "../components/PullQuote.astro";
import CTABand from "../components/CTABand.astro";
import Footer from "../components/Footer.astro";
import { services, processSteps } from "../data/site";
---

<BaseLayout
  title="Virtuoso Psychology · High Performance Specialists"
  description="High performance specialists in sport and business. Know your people, recruit the best, be the best — plain-spoken, evidence-based, never about creating a dependency."
>
  <Header theme="dark" />
  <main id="main-content">
    {/* 1 · Hero with the EMPOWER signature scroll moment */}
    <Hero
      eyebrow="High Performance Specialists · sport & business"
      ctaHref="/contact"
      ctaLabel="Book a discovery call"
      secondaryHref="/services"
      secondaryLabel="How we work"
    />

    {/* 2 · What we do */}
    <Section bg="bg-navy-deep" text="text-cream" pad="lg" ariaLabel="What we do">
      <div class="flex items-end justify-between flex-wrap gap-4 mb-12">
        <div>
          <p class="uppercase tracking-[0.25em] text-xs mb-3 text-gold" style="font-family: var(--font-display-sans);">
            What we do · Teams · Business · Individual · Speaking
          </p>
          <h2 class="text-3xl md:text-5xl leading-[1.05]" style="font-family: var(--font-display-serif); font-weight: 600;">
            Three ways we work with you.
          </h2>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {services.map((s) => (
          <ServiceCard
            number={s.number}
            title={s.title}
            body={s.summary}
            tag={s.tag}
            href={`/services#${s.id}`}
          />
        ))}
      </div>
    </Section>

    {/* 3 · How it works */}
    <Section bg="bg-cream" text="text-ink" pad="lg" ariaLabel="How it works">
      <p class="uppercase tracking-[0.25em] text-xs mb-3 text-gold-deep" style="font-family: var(--font-display-sans);">
        How it works
      </p>
      <h2 class="text-3xl md:text-5xl leading-[1.05] mb-12 max-w-2xl" style="font-family: var(--font-display-serif); font-weight: 600;">
        We listen. We build. We hand over.
      </h2>
      <div class="grid md:grid-cols-3 gap-10">
        {processSteps.map((step) => (
          <ProcessStep number={step.number} title={step.title} body={step.body} />
        ))}
      </div>
    </Section>

    {/* 4 · Credibility */}
    <CredibilityBand />

    {/* 5 · Philosophy pull-quote (verbatim empowerment statement) */}
    <PullQuote />

    {/* 6 · CTA band */}
    <CTABand />
  </main>
  <Footer />
</BaseLayout>
