---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Virtuoso Psychology">
  <main class="min-h-screen flex items-center justify-center p-8 bg-[#faf7f0] text-[#1a1a1a]">
    <div class="max-w-2xl text-center">
      <p class="font-[var(--font-display-sans)] uppercase tracking-[0.2em] text-xs mb-6">
        Virtuoso Psychology
      </p>
      <h1 class="font-[var(--font-display-serif)] text-5xl md:text-7xl leading-[1.05] mb-8">
        Brand &amp; site under construction.
      </h1>
      <p class="text-base md:text-lg leading-relaxed mb-8">
        Phase 0 in progress. Brand guidelines live in
        <code class="bg-black/5 px-1.5 py-0.5 rounded">BRAND.md</code>.
      </p>
      <a
        href="/palettes"
        class="inline-block border border-current px-6 py-3 uppercase tracking-[0.15em] text-sm hover:bg-black hover:text-[#faf7f0] transition-colors duration-200"
      >
        View palette options →
      </a>
    </div>
  </main>
</BaseLayout>
