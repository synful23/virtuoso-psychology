---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Refined Navy & Gold — expanded system
const c = {
  // primary
  navyDeep: "#0B1B33",
  navyMid: "#152A4D",
  navySoft: "#23365E", // new tonal step for cards/hover
  // surface
  cream: "#FAF7F0",
  creamWarm: "#F1E9D6", // section break / quote panel
  paper: "#FFFFFF",
  // accent
  gold: "#D4A24C",
  goldDeep: "#A07628",
  goldSoft: "#E8C988", // for tints/backgrounds
  // ink
  ink: "#1A1A1A",
  inkMuted: "#5B5B60",
  inkOnDark: "#C8C2B0",
};

const serif = "var(--font-display-serif)";
const sans = "var(--font-display-sans)";
---

<BaseLayout title="Option A · Refined Navy & Gold — Virtuoso Psychology" noindex={true}>
  {/* ─── top bar ─── */}
  <header
    class="px-6 md:px-12 py-6 flex items-center justify-between border-b"
    style={`background: ${c.paper}; border-color: ${c.ink}1A;`}
  >
    <p class="uppercase tracking-[0.25em] text-xs" style={`color: ${c.inkMuted}; font-family: ${sans};`}>
      Option A · Deep dive
    </p>
    <a
      href="/palettes"
      class="uppercase tracking-[0.2em] text-xs underline underline-offset-4 hover:opacity-70 transition-opacity"
      style={`color: ${c.ink}; font-family: ${sans};`}
    >
      ← Back to all options
    </a>
  </header>

  {/* ─── intro ─── */}
  <section class="px-6 md:px-12 py-16 md:py-20" style={`background: ${c.paper}; color: ${c.ink};`}>
    <p class="uppercase tracking-[0.25em] text-xs mb-4" style={`color: ${c.goldDeep}; font-family: ${sans};`}>
      Refined Navy & Gold
    </p>
    <h1 class="text-4xl md:text-6xl max-w-3xl leading-[1.05] tracking-[-0.01em]" style={`font-family: ${serif}; font-weight: 600;`}>
      The chosen direction, with a bit more room to breathe.
    </h1>
    <p class="mt-8 max-w-2xl text-base md:text-lg leading-relaxed" style={`color: ${c.inkMuted};`}>
      Same palette you picked &mdash; navy, gold, cream &mdash; now shown across a fuller set of moments:
      a confident hero, a long-form reading surface, services in context, a quote panel, and the
      working system of colours and states. The energy you liked in Option B lives here in the
      <em> typography</em> and <em>layout weight</em>, not the palette.
    </p>
  </section>

  {/* ─── HERO 1: classic editorial ─── */}
  <section style={`background: ${c.navyDeep}; color: ${c.cream};`}>
    <div class="px-6 md:px-12 pt-10 pb-4 flex items-center justify-between border-b" style={`border-color: ${c.cream}1A;`}>
      <p class="uppercase tracking-[0.25em] text-xs" style={`color: ${c.gold}; font-family: ${sans};`}>
        Hero · editorial
      </p>
      <p class="uppercase tracking-[0.2em] text-[10px]" style={`color: ${c.inkOnDark}; font-family: ${sans};`}>
        Fraunces 600 · IBM Plex Sans
      </p>
    </div>

    <div class="px-6 md:px-12 pt-16 md:pt-24 pb-20 md:pb-28 grid md:grid-cols-12 gap-8 items-end">
      <div class="md:col-span-9">
        <p class="uppercase tracking-[0.25em] text-xs mb-6" style={`color: ${c.gold}; font-family: ${sans};`}>
          Sports psychology · for teams & the athletes who lead them
        </p>
        <h2
          class="leading-[0.95] tracking-[-0.02em]"
          style={`font-family: ${serif}; font-weight: 600; font-size: clamp(48px, 9vw, 140px);`}
        >
          Empower the team.<br />
          <span style={`color: ${c.gold};`}>Elevate</span> the game.
        </h2>
        <p class="mt-8 max-w-xl text-base md:text-lg leading-relaxed" style={`color: ${c.inkOnDark};`}>
          We work with squads, individual athletes, and the coaches who lead them.
          Plain-spoken, evidence-based, built around your moment.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="#"
            class="inline-block px-7 py-4 uppercase tracking-[0.15em] text-sm transition-colors duration-200"
            style={`background: ${c.gold}; color: ${c.navyDeep}; font-family: ${sans}; font-weight: 700;`}
            onmouseover={`this.style.background='${c.goldDeep}'; this.style.color='${c.cream}';`}
            onmouseout={`this.style.background='${c.gold}'; this.style.color='${c.navyDeep}';`}
          >
            Book a discovery call →
          </a>
          <a
            href="#"
            class="inline-block px-7 py-4 uppercase tracking-[0.15em] text-sm border transition-colors duration-200"
            style={`border-color: ${c.cream}; color: ${c.cream}; font-family: ${sans}; font-weight: 600;`}
            onmouseover={`this.style.background='${c.cream}'; this.style.color='${c.navyDeep}';`}
            onmouseout={`this.style.background='transparent'; this.style.color='${c.cream}';`}
          >
            How we work
          </a>
        </div>
      </div>

      <div class="md:col-span-3 hidden md:block">
        <div
          class="aspect-[3/4] w-full flex items-center justify-center text-xs uppercase tracking-[0.2em]"
          style={`background: ${c.navyMid}; color: ${c.inkOnDark}; border: 1px solid ${c.cream}1A;`}
        >
          Future film
        </div>
      </div>
    </div>
  </section>

  {/* ─── HERO 2: bolder, more energy ─── */}
  <section style={`background: ${c.cream}; color: ${c.navyDeep};`}>
    <div class="px-6 md:px-12 pt-10 pb-4 flex items-center justify-between border-b" style={`border-color: ${c.navyDeep}1A;`}>
      <p class="uppercase tracking-[0.25em] text-xs" style={`color: ${c.goldDeep}; font-family: ${sans};`}>
        Hero · confident
      </p>
      <p class="uppercase tracking-[0.2em] text-[10px]" style={`color: ${c.inkMuted}; font-family: ${sans};`}>
        Fraunces 800 · tighter · for sections that need to land
      </p>
    </div>

    <div class="px-6 md:px-12 pt-16 md:pt-24 pb-20 md:pb-28">
      <p class="uppercase tracking-[0.25em] text-xs mb-6" style={`color: ${c.goldDeep}; font-family: ${sans};`}>
        Pressure is the job. Performing under it is the skill.
      </p>
      <h2
        class="leading-[0.88] tracking-[-0.035em] max-w-5xl"
        style={`font-family: ${serif}; font-weight: 800; font-size: clamp(56px, 11vw, 180px);`}
      >
        Built for the<br />
        <span style={`color: ${c.goldDeep};`}>moment that matters.</span>
      </h2>
      <div class="mt-10 grid md:grid-cols-12 gap-8 items-start">
        <p class="md:col-span-6 text-base md:text-lg leading-relaxed" style={`color: ${c.inkMuted};`}>
          Cara has worked at the highest level of English football. The methods are simple,
          the standards aren't. This is the same energy &mdash; navy, gold, serif &mdash; carrying
          a bit more weight when a section needs to land harder.
        </p>
        <div class="md:col-span-6 flex flex-wrap gap-4 md:justify-end">
          <a
            href="#"
            class="inline-block px-7 py-4 uppercase tracking-[0.15em] text-sm transition-colors duration-200"
            style={`background: ${c.navyDeep}; color: ${c.cream}; font-family: ${sans}; font-weight: 700;`}
            onmouseover={`this.style.background='${c.navyMid}';`}
            onmouseout={`this.style.background='${c.navyDeep}';`}
          >
            See how we work →
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ─── long-form reading surface ─── */}
  <section style={`background: ${c.paper}; color: ${c.ink};`}>
    <div class="px-6 md:px-12 pt-10 pb-4 flex items-center justify-between border-b" style={`border-color: ${c.ink}1A;`}>
      <p class="uppercase tracking-[0.25em] text-xs" style={`color: ${c.goldDeep}; font-family: ${sans};`}>
        Long-form · about / bio
      </p>
      <p class="uppercase tracking-[0.2em] text-[10px]" style={`color: ${c.inkMuted}; font-family: ${sans};`}>
        For corporate clients reading at length
      </p>
    </div>

    <div class="px-6 md:px-12 py-16 md:py-24 grid md:grid-cols-12 gap-10">
      <aside class="md:col-span-4">
        <div class="aspect-[4/5] w-full" style={`background: ${c.creamWarm}; border: 1px solid ${c.ink}1A;`}>
          <div class="w-full h-full flex items-end p-6">
            <p class="uppercase tracking-[0.25em] text-[10px]" style={`color: ${c.inkMuted}; font-family: ${sans};`}>
              Portrait · Cara
            </p>
          </div>
        </div>
        <div class="mt-6 space-y-2 text-sm" style={`color: ${c.inkMuted}; font-family: ${sans};`}>
          <p><span class="uppercase tracking-[0.15em] text-[11px]" style={`color: ${c.ink};`}>BPS · HCPC</span></p>
          <p>15+ years across elite men's & women's football</p>
          <p>Based in the UK · working internationally</p>
        </div>
      </aside>

      <div class="md:col-span-8">
        <p class="uppercase tracking-[0.25em] text-xs mb-4" style={`color: ${c.goldDeep}; font-family: ${sans};`}>
          About Cara
        </p>
        <h3 class="text-3xl md:text-5xl leading-[1.05] tracking-[-0.01em] mb-8" style={`font-family: ${serif}; font-weight: 600;`}>
          A practitioner first. A psychologist second. A teammate, always.
        </h3>

        <div class="space-y-5 max-w-2xl text-base md:text-[17px] leading-[1.7]" style={`color: ${c.ink}; font-family: ${sans};`}>
          <p>
            Cara has spent over a decade embedded in performance environments &mdash; not as a
            visitor with a clipboard, but as part of the staff. Her work sits at the intersection of
            clinical rigour and the practical realities of a Tuesday morning in a training-ground
            corridor.
          </p>
          <p>
            She doesn't believe in turning athletes into projects. The work begins by listening,
            stays grounded in evidence, and ends where it should &mdash; with the person, the
            squad, or the staff member feeling more capable of the next moment than they did
            before she arrived.
          </p>
          <p>
            Virtuoso Psychology is the formal home for that work: a small, deliberate practice
            built around teams, individuals, and the people who lead them.
          </p>
        </div>

        <div class="mt-10 pt-8 border-t flex flex-wrap gap-x-10 gap-y-4" style={`border-color: ${c.ink}1A;`}>
          {[
            ["Chartered Psychologist", "British Psychological Society"],
            ["Registered Practitioner", "HCPC"],
            ["MSc Sport & Exercise Psychology", "Distinction"],
          ].map(([t, sub]) => (
            <div>
              <p class="uppercase tracking-[0.15em] text-[11px]" style={`color: ${c.goldDeep}; font-family: ${sans}; font-weight: 700;`}>
                {t}
              </p>
              <p class="text-sm mt-1" style={`color: ${c.inkMuted}; font-family: ${sans};`}>
                {sub}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ─── services grid with detail ─── */}
  <section style={`background: ${c.navyDeep}; color: ${c.cream};`}>
    <div class="px-6 md:px-12 pt-10 pb-4 flex items-center justify-between border-b" style={`border-color: ${c.cream}1A;`}>
      <p class="uppercase tracking-[0.25em] text-xs" style={`color: ${c.gold}; font-family: ${sans};`}>
        Services · in context
      </p>
      <p class="uppercase tracking-[0.2em] text-[10px]" style={`color: ${c.inkOnDark}; font-family: ${sans};`}>
        Card hover · gold underline · numeric anchor
      </p>
    </div>

    <div class="px-6 md:px-12 py-16 md:py-20 grid md:grid-cols-3 gap-6">
      {[
        {
          n: "01",
          t: "Teams",
          b: "Workshops, season-long retainers, and culture work for squads, staff, and the people who shape the room.",
          tag: "Most common"
        },
        {
          n: "02",
          t: "Individuals",
          b: "1:1 work for athletes navigating pressure, selection, injury, transitions, and identity beyond performance.",
          tag: null
        },
        {
          n: "03",
          t: "Speaking",
          b: "Keynotes and bespoke sessions for clubs, federations, governing bodies, and corporate audiences.",
          tag: null
        },
      ].map((s) => (
        <article
          class="p-7 transition-all duration-200 cursor-pointer group"
          style={`background: ${c.navyMid}; border-top: 2px solid ${c.gold};`}
          onmouseover={`this.style.background='${c.navySoft}'; this.style.transform='translateY(-2px)';`}
          onmouseout={`this.style.background='${c.navyMid}'; this.style.transform='translateY(0)';`}
        >
          <div class="flex items-start justify-between mb-6">
            <p class="uppercase tracking-[0.2em] text-xs" style={`color: ${c.gold}; font-family: ${sans}; font-weight: 700;`}>
              {s.n}
            </p>
            {s.tag && (
              <p
                class="uppercase tracking-[0.18em] text-[10px] px-2 py-1"
                style={`background: ${c.gold}; color: ${c.navyDeep}; font-family: ${sans}; font-weight: 700;`}
              >
                {s.tag}
              </p>
            )}
          </div>
          <h4 class="text-3xl mb-4" style={`font-family: ${serif}; font-weight: 600;`}>
            {s.t}
          </h4>
          <p class="text-sm leading-relaxed mb-6" style={`color: ${c.inkOnDark};`}>
            {s.b}
          </p>
          <p class="uppercase tracking-[0.2em] text-xs" style={`color: ${c.gold}; font-family: ${sans}; font-weight: 600;`}>
            Explore →
          </p>
        </article>
      ))}
    </div>
  </section>

  {/* ─── quote panel ─── */}
  <section style={`background: ${c.creamWarm}; color: ${c.navyDeep};`}>
    <div class="px-6 md:px-12 py-24 md:py-32 text-center">
      <p
        class="max-w-4xl mx-auto leading-[1.15] tracking-[-0.01em]"
        style={`font-family: ${serif}; font-style: italic; font-weight: 400; font-size: clamp(28px, 4.2vw, 60px);`}
      >
        "Performance is collective. Even the work we do one-to-one happens in the context of
        <span style={`color: ${c.goldDeep}; font-style: normal; font-weight: 600;`}> a team, a coach, a relationship</span>."
      </p>
      <p class="mt-10 uppercase tracking-[0.25em] text-xs" style={`color: ${c.inkMuted}; font-family: ${sans};`}>
        Cara &middot; Founder, Virtuoso Psychology
      </p>
    </div>
  </section>

  {/* ─── the working system ─── */}
  <section style={`background: ${c.paper}; color: ${c.ink};`}>
    <div class="px-6 md:px-12 pt-10 pb-4 flex items-center justify-between border-b" style={`border-color: ${c.ink}1A;`}>
      <p class="uppercase tracking-[0.25em] text-xs" style={`color: ${c.goldDeep}; font-family: ${sans};`}>
        The working system
      </p>
      <p class="uppercase tracking-[0.2em] text-[10px]" style={`color: ${c.inkMuted}; font-family: ${sans};`}>
        Colours · roles · usage
      </p>
    </div>

    <div class="px-6 md:px-12 py-16 md:py-20">
      {/* primary */}
      <div class="mb-14">
        <h3 class="text-2xl md:text-3xl mb-2" style={`font-family: ${serif}; font-weight: 600;`}>
          Primary · navy
        </h3>
        <p class="text-sm mb-6 max-w-xl" style={`color: ${c.inkMuted};`}>
          The brand's anchor. Use deep navy for hero surfaces and headers, mid for cards and panels,
          soft for hover and the secondary tier.
        </p>
        <div class="grid grid-cols-3 gap-3 max-w-2xl">
          {[
            { label: "Deep", hex: c.navyDeep, on: c.cream },
            { label: "Mid", hex: c.navyMid, on: c.cream },
            { label: "Soft (new)", hex: c.navySoft, on: c.cream },
          ].map((s) => (
            <div class="aspect-[4/3] p-3 flex flex-col justify-between text-[11px]" style={`background: ${s.hex}; color: ${s.on};`}>
              <span class="uppercase tracking-[0.15em]" style={`font-family: ${sans};`}>{s.label}</span>
              <span class="font-mono">{s.hex}</span>
            </div>
          ))}
        </div>
      </div>

      {/* accent */}
      <div class="mb-14">
        <h3 class="text-2xl md:text-3xl mb-2" style={`font-family: ${serif}; font-weight: 600;`}>
          Accent · gold
        </h3>
        <p class="text-sm mb-6 max-w-xl" style={`color: ${c.inkMuted};`}>
          Gold is for emphasis, never furniture. Use it on a word in a headline, on a CTA, on an
          eyebrow tag &mdash; not on body copy and not as a background block at scale. Deep gold is
          the hover/pressed state; soft gold is for tints and tags only.
        </p>
        <div class="grid grid-cols-3 gap-3 max-w-2xl">
          {[
            { label: "Gold", hex: c.gold, on: c.navyDeep },
            { label: "Gold deep", hex: c.goldDeep, on: c.cream },
            { label: "Gold soft (new)", hex: c.goldSoft, on: c.navyDeep },
          ].map((s) => (
            <div class="aspect-[4/3] p-3 flex flex-col justify-between text-[11px]" style={`background: ${s.hex}; color: ${s.on};`}>
              <span class="uppercase tracking-[0.15em]" style={`font-family: ${sans};`}>{s.label}</span>
              <span class="font-mono">{s.hex}</span>
            </div>
          ))}
        </div>
      </div>

      {/* surface */}
      <div class="mb-14">
        <h3 class="text-2xl md:text-3xl mb-2" style={`font-family: ${serif}; font-weight: 600;`}>
          Surface · cream & paper
        </h3>
        <p class="text-sm mb-6 max-w-xl" style={`color: ${c.inkMuted};`}>
          Two reading surfaces. Cream is the warm default for long-form and feature blocks; paper
          is the cool surface for navy-on-white moments. Cream-warm is the in-between for quote
          panels and section breaks.
        </p>
        <div class="grid grid-cols-3 gap-3 max-w-2xl">
          {[
            { label: "Cream", hex: c.cream, on: c.navyDeep },
            { label: "Cream warm (new)", hex: c.creamWarm, on: c.navyDeep },
            { label: "Paper", hex: c.paper, on: c.navyDeep },
          ].map((s) => (
            <div class="aspect-[4/3] p-3 flex flex-col justify-between text-[11px]" style={`background: ${s.hex}; color: ${s.on}; border: 1px solid ${c.ink}1A;`}>
              <span class="uppercase tracking-[0.15em]" style={`font-family: ${sans};`}>{s.label}</span>
              <span class="font-mono">{s.hex}</span>
            </div>
          ))}
        </div>
      </div>

      {/* ink */}
      <div class="mb-14">
        <h3 class="text-2xl md:text-3xl mb-2" style={`font-family: ${serif}; font-weight: 600;`}>
          Ink · text
        </h3>
        <p class="text-sm mb-6 max-w-xl" style={`color: ${c.inkMuted};`}>
          Three text tones. Ink for headlines and body on light surfaces; ink-muted for supporting
          copy; ink-on-dark for body copy over navy.
        </p>
        <div class="grid grid-cols-3 gap-3 max-w-2xl">
          {[
            { label: "Ink", hex: c.ink, on: c.cream },
            { label: "Ink muted", hex: c.inkMuted, on: c.cream },
            { label: "Ink on dark", hex: c.inkOnDark, on: c.navyDeep },
          ].map((s) => (
            <div class="aspect-[4/3] p-3 flex flex-col justify-between text-[11px]" style={`background: ${s.hex}; color: ${s.on};`}>
              <span class="uppercase tracking-[0.15em]" style={`font-family: ${sans};`}>{s.label}</span>
              <span class="font-mono">{s.hex}</span>
            </div>
          ))}
        </div>
      </div>

      {/* button states */}
      <div>
        <h3 class="text-2xl md:text-3xl mb-2" style={`font-family: ${serif}; font-weight: 600;`}>
          Buttons · states
        </h3>
        <p class="text-sm mb-6 max-w-xl" style={`color: ${c.inkMuted};`}>
          Hover the buttons. Primary inverts to navy-on-cream on press; secondary fills with cream.
        </p>
        <div class="flex flex-wrap gap-4 items-center">
          <a
            href="#"
            class="inline-block px-7 py-4 uppercase tracking-[0.15em] text-sm transition-colors duration-200"
            style={`background: ${c.gold}; color: ${c.navyDeep}; font-family: ${sans}; font-weight: 700;`}
            onmouseover={`this.style.background='${c.goldDeep}'; this.style.color='${c.cream}';`}
            onmouseout={`this.style.background='${c.gold}'; this.style.color='${c.navyDeep}';`}
          >
            Primary CTA →
          </a>
          <a
            href="#"
            class="inline-block px-7 py-4 uppercase tracking-[0.15em] text-sm transition-colors duration-200"
            style={`background: ${c.navyDeep}; color: ${c.cream}; font-family: ${sans}; font-weight: 700;`}
            onmouseover={`this.style.background='${c.navyMid}';`}
            onmouseout={`this.style.background='${c.navyDeep}';`}
          >
            Primary on light →
          </a>
          <a
            href="#"
            class="inline-block px-7 py-4 uppercase tracking-[0.15em] text-sm border transition-colors duration-200"
            style={`border-color: ${c.navyDeep}; color: ${c.navyDeep}; font-family: ${sans}; font-weight: 600;`}
            onmouseover={`this.style.background='${c.navyDeep}'; this.style.color='${c.cream}';`}
            onmouseout={`this.style.background='transparent'; this.style.color='${c.navyDeep}';`}
          >
            Secondary
          </a>
          <a
            href="#"
            class="inline-block uppercase tracking-[0.2em] text-xs pb-1 transition-colors duration-200"
            style={`color: ${c.goldDeep}; border-bottom: 1px solid ${c.goldDeep}; font-family: ${sans}; font-weight: 700;`}
            onmouseover={`this.style.color='${c.navyDeep}'; this.style.borderColor='${c.navyDeep}';`}
            onmouseout={`this.style.color='${c.goldDeep}'; this.style.borderColor='${c.goldDeep}';`}
          >
            Inline link →
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ─── footer mock ─── */}
  <footer style={`background: ${c.navyDeep}; color: ${c.inkOnDark};`}>
    <div class="px-6 md:px-12 py-16 grid md:grid-cols-12 gap-10">
      <div class="md:col-span-5">
        <p class="uppercase tracking-[0.3em] text-xs mb-4" style={`color: ${c.gold}; font-family: ${sans};`}>
          Virtuoso Psychology
        </p>
        <h4 class="text-2xl md:text-3xl leading-[1.15]" style={`font-family: ${serif}; font-weight: 600; color: ${c.cream};`}>
          Empower the team. <span style={`color: ${c.gold};`}>Elevate</span> the game.
        </h4>
      </div>
      <div class="md:col-span-3">
        <p class="uppercase tracking-[0.2em] text-[11px] mb-4" style={`color: ${c.gold}; font-family: ${sans};`}>Site</p>
        <ul class="space-y-2 text-sm" style={`font-family: ${sans};`}>
