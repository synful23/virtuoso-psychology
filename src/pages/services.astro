---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import CTABand from "../components/CTABand.astro";
import { services, site, seo } from "../data/site";

const meta = seo.services;

// One Service node per offering, generated from the same `services[]` array the
// page renders — so structured data never drifts from visible content. Each
// references the site-wide Organization (@id from BaseLayout) as provider.
const servicesJsonLd = services.map((s) => ({
  "@context": "https://schema.org",
  "@type": "Service",
  name: s.title,
  serviceType: s.title,
  description: s.who,
  provider: { "@id": `${site.url}/#organisation` },
  areaServed: [...site.areaServed],
  url: `${site.url}/services#${s.id}`,
}));
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  ogImage={meta.ogImage}
  jsonLd={servicesJsonLd}
>
  <Header theme="light" />
  <main id="main-content">
    {/* Intro */}
    <section class="bg-paper text-ink">
      <div class="px-6 md:px-12 py-16 md:py-24">
        <p class="uppercase tracking-[0.25em] text-xs mb-4 text-gold-deep" style="font-family: var(--font-display-sans);">
          Services
        </p>
        <h1 class="text-4xl md:text-6xl max-w-3xl leading-[1.05] tracking-[-0.01em]" style="font-family: var(--font-display-serif); font-weight: 600;">
          Harness your strengths.
        </h1>
        <p class="mt-8 max-w-2xl text-base md:text-lg leading-relaxed text-ink-muted">
          Know your people, Recruit the best, be the best.
        </p>
        <nav class="mt-10 flex flex-wrap gap-x-6 gap-y-2" aria-label="Services">
          {services.map((s) => (
            <a
              href={`#${s.id}`}
              class="uppercase tracking-[0.18em] text-xs pb-1 border-b border-transparent text-ink-muted hover:text-ink hover:border-ink transition-colors duration-200"
              style="font-family: var(--font-display-sans);"
            >
              {s.number} · {s.title}
            </a>
          ))}
        </nav>
      </div>
    </section>

    {services.map((s, i) => {
      const dark = i % 2 === 0;
      return (
        <section
          id={s.id}
          class:list={[dark ? "bg-navy-deep text-cream" : "bg-cream text-ink", "scroll-mt-24 border-t", dark ? "border-cream/10" : "border-ink/10"]}
        >
          <div class="px-6 md:px-12 py-16 md:py-24 grid md:grid-cols-12 gap-10">
            <div class="md:col-span-4">
              <p
                class:list={["uppercase tracking-[0.2em] text-xs mb-4 font-bold", dark ? "text-gold" : "text-gold-deep"]}
                style="font-family: var(--font-display-sans);"
              >
                {s.number}
              </p>
              <h2 class="text-4xl md:text-5xl leading-[1.0]" style="font-family: var(--font-display-serif); font-weight: 600;">
                {s.title}
              </h2>
              {s.tag && (
                <p
                  class="inline-block mt-5 uppercase tracking-[0.18em] text-[10px] px-2 py-1 bg-gold text-navy-deep font-bold"
                  style="font-family: var(--font-display-sans);"
                >
                  {s.tag}
                </p>
              )}
            </div>

            <div class="md:col-span-8">
              <p class:list={["text-lg md:text-xl leading-relaxed mb-10", dark ? "text-ink-on-dark" : "text-ink"]}>
                {s.who}
              </p>

              <div class="grid sm:grid-cols-2 gap-10">
                <div>
                  <h3
                    class:list={["uppercase tracking-[0.18em] text-[11px] mb-4 font-bold", dark ? "text-gold" : "text-gold-deep"]}
                    style="font-family: var(--font-display-sans);"
                  >
                    What's included
                  </h3>
                  <ul class="space-y-2 text-sm" style="font-family: var(--font-display-sans);">
                    {s.includes.map((item) => (
                      <li class:list={["flex gap-3", dark ? "text-ink-on-dark" : "text-ink-muted"]}>
                        <span class:list={[dark ? "text-gold" : "text-gold-deep"]} aria-hidden="true">—</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <h3
                    class:list={["uppercase tracking-[0.18em] text-[11px] mb-4 font-bold", dark ? "text-gold" : "text-gold-deep"]}
                    style="font-family: var(--font-display-sans);"
                  >
                    The outcome
                  </h3>
                  <p class:list={["text-sm leading-relaxed", dark ? "text-ink-on-dark" : "text-ink-muted"]}>
                    {s.outcome}
                  </p>
                </div>
              </div>

              <div class="mt-10">
                <Button href="/contact" variant={dark ? "primary" : "secondary-light"}>
                  Enquire about {s.title.toLowerCase()} →
                </Button>
              </div>
            </div>
          </div>
        </section>
      );
    })}

    {/* Why it matters — the recruitment & culture rationale */}
    <section class="bg-paper text-ink border-t border-ink/10">
      <div class="px-6 md:px-12 py-16 md:py-24 grid md:grid-cols-12 gap-10">
        <div class="md:col-span-4">
          <p class="uppercase tracking-[0.2em] text-xs mb-4 text-gold-deep font-bold" style="font-family: var(--font-display-sans);">
            Why it matters
          </p>
          <h2 class="text-3xl md:text-5xl leading-[1.05] tracking-[-0.01em]" style="font-family: var(--font-display-serif); font-weight: 600;">
            High performance is built, not left to chance.
          </h2>
        </div>

        <div class="md:col-span-8 max-w-2xl space-y-6 text-base md:text-[17px] leading-[1.7] text-ink" style="font-family: var(--font-display-sans);">
          <p>
            Performing well under pressure, consistently, asks a complex and
            evolving set of variables to function well, work in harmony, and deeply
            understand one another. Culture and environment are worth investing in:
            the conditions you create around your people are fundamental to high
            performance, supporting each individual to regulate, flourish, and cope
            with the demands they meet in the moments that matter most. That isn't
            created by chance — it takes deliberate design and attention. We help and
            empower your organisation to take the lead and thrive.
          </p>
          <p>
            When the environment is right, we focus on the people. Recruitment is
            more than data metrics and generic personality profiling. A successful
            recruit takes deep knowledge and understanding of the individual, their
            world, and their relationship dynamics. That knowledge is a skill — we
            offer expert insight into the recruitment and onboarding of talent,
            making sure the conditions are conducive to consistent high performance.
          </p>
          <p>
            And the cost of getting it wrong? Research suggests that somewhere
            between 30–50% of these investments don't go to plan. As well as being
            financially costly, that can carry reputational damage and real
            difficulty for the individual involved. These failings aren't the
            individual's responsibility, but a mismatch of all the variables that
            sit around the process. Our service helps fill the gaps in knowledge that
            data alone can't provide — sitting alongside your technical, tactical, and
            financial evaluations.
          </p>
          <p>
            We are completely impartial and independent, with one primary focus:
            working with you to ensure the successful adaptation of your talent and
            maximise their potential. Research suggests that even a 10% improvement in
            the adaptation and onboarding of talent could equate to significant
            retention value each year. So — do you want to jump the curve? We'll help
            you build the processes, work with your staff, support recruitment and
            onboarding, and empower your team to take it from there.
          </p>
        </div>
      </div>
    </section>

    <CTABand
      heading="Not sure which fits?"
      body="That's the most common place to start. Tell us about your moment and we'll point you the right way."
      ctaLabel="Start the conversation"
    />
  </main>
  <Footer />
</BaseLayout>
